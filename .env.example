# SIO Insights GitHub App — credentials template
#
# Copy to `.env` and fill in after registering the App (see docs/GITHUB-APP.md).
# NEVER commit the real `.env` — it is git-ignored. All values below are
# returned by GitHub's App Manifest flow or found on the App's settings page.

# Numeric App ID (App settings → "About").
GITHUB_APP_ID=

# OAuth client id / secret (App settings → "Client secrets").
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Webhook secret generated during the manifest flow. Used by
# scripts/webhook-verify.js to authenticate the X-Hub-Signature-256 header.
GITHUB_APP_WEBHOOK_SECRET=

# Path to the PEM private key downloaded on the App page. Keep it outside the
# repo. Used to mint short-lived installation tokens.
GITHUB_APP_PRIVATE_KEY_PATH=./sio-insights-app.private-key.pem

# Installation id for this repo (App → Install App, or read from the
# `installation.id` field of any webhook payload).
GITHUB_APP_INSTALLATION_ID=
