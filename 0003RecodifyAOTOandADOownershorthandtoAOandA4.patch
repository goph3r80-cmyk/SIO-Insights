 explainer.html | 4 ++--
 index.html     | 4 ++--
 2 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/explainer.html b/explainer.html
index b0b4489..f0bf646 100644
--- a/explainer.html
+++ b/explainer.html
@@ -510,8 +510,8 @@
