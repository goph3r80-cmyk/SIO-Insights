# Portfolio tracker configuration — copy to .env (git-ignored). Never put
# brokerage passwords here; the tracker never asks for trading permissions.

# Where the SQLite database and file store live (default: ./data)
#PORTFOLIO_DATA_DIR=./data
#PORTFOLIO_DB=./data/portfolio.db
#PORTFOLIO_BACKUP_DIR=./data/backups

# Market data / FX providers (free & keyless by default). If you connect a
# provider that needs a key, use READ-ONLY API keys only.
#MARKET_DATA_PROVIDER=stooq
#FX_PROVIDER=frankfurter

# Optional email alerts (local alerts work without any of this)
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM=portfolio@localhost
#ALERT_EMAIL_TO=
